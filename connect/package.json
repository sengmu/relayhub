{
  "name": "sub2api-connect",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop connector for sub2api on Windows, macOS, and Linux.",
  "homepage": "https://github.com/sengmu/relayhub",
  "repository": {
    "type": "git",
    "url": "https://github.com/sengmu/relayhub.git"
  },
  "author": {
    "name": "sengmu",
    "email": "linguihong000@gmail.com"
  },
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 ELECTRON_DISABLE_SANDBOX=1 electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:electron",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis zip",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vue-tsc": "^3.0.4",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "org.sub2api.connect",
    "productName": "sub2api Connect",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "deb", "tar.gz"],
      "category": "Development",
      "maintainer": "sub2api Team <noreply@sub2api.local>"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
